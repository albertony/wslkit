#!/bin/sh
#
# Configure pacman.
#
# Assuming this script is run immediately after a clean install, we must ensure
# that pacman is configured to be able to install the packages we want.
# Therefore we start by configuring a package repository mirror, and then
# initialize the pacman keyring. In addition, configures some relevant options
# in pacman.conf, mostly for convenience.
#
# When setting mirror, this moves away any existing mirrorlist file by adding
# suffix .old.<random>, and then creates a new file with a single specific
# mirror. Will try to check if the mirror is already enabled in the file, but
# does not assume tools grep, sed or awk are available to perform this check
# properly, because in old versions of the bootstrap archive they were not
# included, and of course we need to setup pacman before we can install them
# (see arch-setup-packages). If none of the tools are available, then using a
# fallback method which is very simplistic and may end up recreating the file
# unnecessary.
#
# On a clean bootstrap archive there is a default mirrorlist file that contains
# all mirrors commented out. The official Arch WSL distro bundles a custom
# mirrorlist file with two mirrors configured. It currently prefers the
# worldwide CDN mirror from Fastly, a sponsor of the Arch project providing
# Hosting/CDN services. This mirror is not a traditional mirror, but a Content
# Delivery Network service, caching content directly from the authoritative
# source mirror.pkgbuild.com that is running on the Arch Linux Team's own
# infrastructure. Previously the default mirrorlist was configured with the
# Arch Linux Team's own worldwide GeoDNS mirror service, distributing requests
# directly to a specific regional subdomain of mirror.pkgbuild.com based on
# location, and this is still kept as a fall-back, but Fastly is now considered
# a better and faster alternative. The bundled mirrorlist file looks like this:
#   Server = https://fastly.mirror.pkgbuild.com/$repo/os/$arch
#   Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch
# Rackspace is another worldwide mirror with strong reputation, historically
# used a lot as a default or fall-back:
#   Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
# Here we use the Fastly CDN as default, but variable ARCH_SETUP_MIRROR can be
# set to use something else. Note that this must be the address only to the
# root of the mirror server and without trailing slash, e.g.
# "https://fastly.mirror.pkgbuild.com", as "/$repo/os/$arch" will be appended
# when written to the mirrorlist file.
#
# On a clean system installed from bootstrap archive there should be no keys,
# i.e. no folder /etc/pacman.d/gnupg, but in case we have tried before without
# luck we delete it which forces resetting of all keys as described here:
# https://wiki.archlinux.org/index.php/Pacman/Package_signing#Resetting_all_the_keys
#
# When using the official WSL distro a similar task may have already been done:
# It has preconfigured a couple of default urls in the bundled mirrorlist file,
# and on first startup it initializes the pacman keyring. In this case we will
# still just reset all keys (although unnecessary at this point) and create a
# new mirrorlist file (with our own preferred urls), as described above.
#
# The "pacman-key --init" command executed below will on a clean install of
# bootstrap archive as of 2021.02.01 report an error due to missing awk
# command. It does enough that "pacman-key --populate archlinux" can be run
# next (and that fails without the initial "pacman-key --init"), after which
# we are able to install packages (which we can not without these two
# commands). Don't know the state of the generated keys in this situation, so
# would probably want to install gawk and reset the keys as described here:
# https://wiki.archlinux.org/index.php/Pacman/Package_signing#Resetting_all_the_keys
# But gawk is actually installed by default, it is just not available as "awk"!
# There is a symlink /usr/bin/awk pointing to /usr/bin/gawk, but
# /usr/bin/gawk does not exist, while there is an executable
# /usr/bin/gawk-5.1.0 which does! So we find it and copy it into /usr/bin/awk
# (or rather /usr/bin/gawk which /usr/bin/awk is a symlink to). Reinstalling
# the gawk package would have done the same.
#

# Verify running as root (not relying on sudo which may not be installed yet).
if [ ${EUID:-$(id -u)} -ne 0 ]; then
    echo 'Please run this script as root' >&2
    exit 1
fi

# Make sure awk is linked.
# It is required by pacman-key --init as described above. Since we do not want
# to assume tools such as grep or sed are available for manipulation of
# configuration files elsewhere in this script, this means we can consider awk
# as a tool, and therefore we do this section early!
awk=/usr/bin/awk
if [ -e "$awk" ]; then
    if [ -x "$awk" ]; then
        echo "Required awk command found at $awk";
    else
        # Strange - it exists but is not an executable file!?
        echo "WARNING: Required awk command not found, 'pacman-key --init' will probably report an error. When this script is completed, you should consider resetting all the pacman keys as described here: https://wiki.archlinux.org/index.php/Pacman/Package_signing#Resetting_all_the_keys"
    fi
else
    # Find any *awk* executable in /usr/bin.
    realawk=$(find /usr/bin -type f -executable -name "*awk*" -print -quit)
    if [ -z "$realawk" ]; then
        echo "WARNING: Required awk command not found, 'pacman-key --init' will probably report an error. When this script is completed, you should consider resetting all the pacman keys as described here: https://wiki.archlinux.org/index.php/Pacman/Package_signing#Resetting_all_the_keys"
    else
        # Found an alternative awk command, e.g. /usr/bin/gawk-5.1.0, make a copy of that as /usr/bin/awk.
        if [ -h "$awk" ]; then
            # Primary awk command path exists but is a symlink to non-existing file.
            # Locate the target of the symlink, so we can copy into that instead
            # of replacing the symlink!
            awk=$(readlink --canonicalize --no-newline /usr/bin/awk)
        fi
        echo "NOTICE: Required awk command missing but found $realawk, so will copy it to $awk"
        cp "$realawk" "$awk"
    fi
    unset realawk
fi
unset awk

# Configure package repository mirror.
# If there is an existing mirrorlist file, we check if the requested package
# repository mirror is the first, or primary, of all active/uncommented
# mirror configuration lines (pacman tries mirrors in the order they appear in
# the mirrorlist file). If not, then we rename this mirrorlist file to .old
# followed by some random numbers, and create a new. Pacman will typically also
# create file mirrorlist.pacnew on update, so this strategy is sort of in line
# with that.
# Note: Doing this first, before the "pacman-key --init" command, because it
# uses this, and if the file does not exist it will report an error (but continue):
#   error: config file /etc/pacman.d/mirrorlist could not be read: No such file or directory
mirrorhost=${ARCH_SETUP_MIRROR:-https://fastly.mirror.pkgbuild.com}
mirrorconfig="Server = ${mirrorhost}/\$repo/os/\$arch"
echo "Configuring package repository mirror ${mirrorhost}"
if [ -f "/etc/pacman.d/mirrorlist" ]; then
    # Making no assumptions, grep was not always included in the bootstrap
    # archive, and we need to setup pacman before we can install any additional
    # tools (see arch-setup-packages).
    if command -v grep > /dev/null 2>&1; then
        mirrorlist=$(grep '^Server = ' /etc/pacman.d/mirrorlist)
    elif command -v sed > /dev/null 2>&1; then
        mirrorlist=$(sed -n '/^Server = /p' /etc/pacman.d/mirrorlist)
    elif command -v awk > /dev/null 2>&1; then
        mirrorlist=$(awk '/^Server = /' /etc/pacman.d/mirrorlist)
    else
        echo "WARNING: Doing a simplistic check for existing configuration because grep/sed/awk is missing"
        mirrorlist="$(tail --lines=1 /etc/pacman.d/mirrorlist 2> /dev/null)"
    fi
    if [ -z "$mirrorlist" ]; then
        mirrorcount=0
    else
        mirrorcount=$(echo "$mirrorlist" | wc -l)
    fi
    echo "Mirrorlist file exists with ${mirrorcount} active mirror(s) configured"
    if [ -n "$mirrorlist" ]; then
        echo "$mirrorlist"
    fi
    if [ "$(echo "$mirrorlist" | head -1)" = "$mirrorconfig" ]; then
        echo "The requested mirror is already configured as primary"
        echo "Keeping existing mirrorlist file unchanged"
        if [ "$mirrorcount" -gt 1 ]; then
            echo "WARNING: There are additional lower priority mirrors configured (${mirrorcount} in total)"
        fi
    else
        echo "The requested mirror is not already configured as primary"
        mirrorlist_backup=$(mktemp --tmpdir=/etc/pacman.d mirrorlist.old.XXXXX)
        echo "Moving existing mirrorlist file out of the way as '$mirrorlist_backup'"
        if ! mv /etc/pacman.d/mirrorlist "$mirrorlist_backup"; then
            echo "Failed!" >&2
            exit 1
        fi
        echo "Writing new mirrorlist file with only the requested mirror"
        if ! echo "$mirrorconfig" > /etc/pacman.d/mirrorlist; then
            echo "Failed!" >&2
            echo "Trying to restore backup" >&2
            if ! mv "$mirrorlist_backup" /etc/pacman.d/mirrorlist; then
                echo "Failed!" >&2
                echo "Please check '/etc/pacman.d/mirrorlist' and compare with original backup '${mirrorlist_backup}'" >&2
            fi
            exit 1
        fi
        unset mirrorlist_backup
    fi
    unset mirrorcount mirrorlist
else
    echo "Writing new mirrorlist file"
    if ! echo "$mirrorconfig" > /etc/pacman.d/mirrorlist; then
        echo "Failed!" >&2
        exit 1
    fi
fi
unset mirrorconfig mirrorhost

# Configure pacman options by uncommenting, commenting out, or adding them in
# /etc/pacman.conf. Options prefixed with '#' will be commented out (disabled),
# others will be uncommented (enabled).
#
# Assuming normally using a proper terminal emulator that handles escape codes
# etc, the following options are set:
# - "Color"
#   - Enables automatic coloring with option "Color" (feature introduced with
#     pacman 4.1).
#   - This corresponds to running pacman with option "--color auto".
#   - It can be temporarily disabled back to original setting by running with
#     option "--color never".
# - "#NoProgressBar"
#   - Re-enables the progress bar by commenting out option "NoProgressBar".
#   - The NoProgressBar option can be temporarily re-enabled by running
#     pacman with --noprogressbar.
# - "VerbosePkgLists"
#   - Displays a more detailed tabular format of packages to be
#     upgraded/installed/removed, including old version, new version, and size
#     changes.
# - "#CheckSpace"
#   - Disables the check for available disk space before installing packages.
#   - Not particularly relevant in WSL, with virtualized, dynamically expanding
#     disk.
#
# The pacman.conf in the original Arch pacman package has "#Color" and
# "#NoProgressBar" (both commented out), but the Arch WSL image has merged in
# changes from the Arch Devtools repo into its chroot build environment, and it
# sets the same "#Color" while changing to uncommented "NoProgressBar". It does
# that probably to ensure there is no noise from escape codes and progress bars
# in build logs, and this "leaks" into the WSL image. We want to get the
# progress bar back as in the original, and we want the additional coloring,
# assuming WSL distro is typically used interactively and from a capable
# terminal. The Devtools repo also changes to "VerbosePkgLists", which provides
# a more detailed tabular format of packages to be upgraded/installed/removed,
# which is quite informative and therefore we keep that - and sets it if not
# already set. Finally, the Devtools repo also changes to "#CheckSpace", with a
# note: "We cannot check disk space from within a chroot environment". This
# seems sensible to keep in WSL as well, as the free space of a virtualized
# dynamically expanding disk is not so relevant.
# https://gitlab.archlinux.org/archlinux/devtools/-/blob/master/config/pacman/extra.conf
echo "Configuring pacman options"
for option in Color "#NoProgressBar" "#CheckSpace" "VerbosePkgLists"; do
    echo "Checking ${option}"
    if [ "${option#\#}" = "$option" ]; then
        active_pat="^${option}$"
        active_val="${option}"
        inactive_pat="^#${option}$"
    else
        option="${option#\#}"
        active_pat="^#${option}$"
        active_val="#${option}"
        inactive_pat="^${option}$"
    fi
    state=missing
    if command -v grep > /dev/null 2>&1; then
        grep -q "$active_pat"   /etc/pacman.conf && state=active
        grep -q "$inactive_pat" /etc/pacman.conf && state=inactive
    elif command -v sed > /dev/null 2>&1; then
        [ -n "$(sed -n "/${active_pat}/p"   /etc/pacman.conf)" ] && state=active
        [ -n "$(sed -n "/${inactive_pat}/p" /etc/pacman.conf)" ] && state=inactive
    elif command -v awk > /dev/null 2>&1; then
        awk "/${active_pat}/{found=1}END{exit 1-found}"   /etc/pacman.conf && state=active
        awk "/${inactive_pat}/{found=1}END{exit 1-found}" /etc/pacman.conf && state=inactive
    else
        echo "WARNING: Cannot detect state without grep, sed, or awk, skipping" >&2
        continue
    fi
    case "$state" in
        active)
            echo "Already set"
            ;;
        inactive)
            echo "Changing existing option"
            if command -v sed > /dev/null 2>&1; then
                tmp=$(mktemp)
                sed "s/${inactive_pat}/${active_val}/" /etc/pacman.conf > "$tmp" \
                    && chmod --reference=/etc/pacman.conf "$tmp" \
                    && mv "$tmp" /etc/pacman.conf || { echo "Failed!" >&2; rm -f "$tmp"; exit 1; }
                unset tmp
            elif command -v awk > /dev/null 2>&1; then
                tmp=$(mktemp)
                awk "/${inactive_pat}/{print \"${active_val}\"; next} {print}" /etc/pacman.conf > "$tmp" \
                    && chmod --reference=/etc/pacman.conf "$tmp" \
                    && mv "$tmp" /etc/pacman.conf || { echo "Failed!" >&2; rm -f "$tmp"; exit 1; }
                unset tmp
            else
                echo "WARNING: Cannot modify without sed or awk, skipping" >&2
            fi
            ;;
        missing)
            echo "Adding as new option"
            printf '\n%s\n' "$active_val" >> /etc/pacman.conf \
                || { echo "Failed!" >&2; exit 1; }
            ;;
    esac
done
unset option active_pat active_val inactive_pat state

# Initialize pacman.
if [ -e /etc/pacman.d/gnupg ]; then
    echo "NOTICE: Existing pacman keys will be reset" # In case we have tried before without luck!?
    rm -rf /etc/pacman.d/gnupg
fi
pacman-key --init
pacman-key --populate > /dev/null
