#!/bin/sh
#
# Update package database and upgrade packages to latest version.
#
# By default this performs a regular update: it refreshes the package database
# without forcing a refresh if it appears to be up-to-date, and upgrades
# packages without allowing downgrades. The main upgrade is performed by a
# pacman command with the -Syu option, which seems to be the recommended
# approach for normal upgrades on Arch Linux.
#
# With the --force option this instead performs a full forced update: it forces
# a refresh of the package database even if it appears to be up-to-date, using
# double --refresh options, and allows downgrading packages using double
# --sysupgrade options. This is usually only necessary when switching package
# repositories.
#
# This takes a thorough, robust and clean approach. It accounts for changes to
# the signing keys, which may otherwise lead to errors such as "unknown trust"
# or "marginal trust" during package upgrades, especially if the system is not
# upgraded regularly. The solution is to manually sync the package database and
# upgrade the archlinux-keyring package before upgrading other packages. Then it
# upgrades all other packages, without performing an unnecessary extra sync of
# the package database. After that, it performs cleanup by removing (uninstalling)
# any packages that are no longer required, considering packages that were not
# explicitly installed, but originally installed as a dependency of other packages,
# even as an optional dependency. When dependency relations are removed as part of a
# packages upgrade, the dependent packages are normally left behind. These are also
# known as orphans. Finally, it cleans up the package database (cache), removing
# packages that are no longer installed to free up disk space.
#
# Options:
#   --force             Force package database refresh and allow downgrades.
#   --noconfirm         Do not prompt for confirmation (passed to pacman).
#   --noprogressbar     Do not show progress bar (passed to pacman).
#   --quiet, -q         Suppress output where possible (passed to pacman).
#   --verbose, -v       Produce extra/verbose output (passed to pacman).
#   --color <when>      Colorize output: always, never, or auto (passed to pacman).
#
# Everything done in this script could be boiled down to the following one-liner
# for the regular (default) case:
#   pacman --sync --refresh --needed archlinux-keyring && pacman --sync --sysupgrade && pacman --query --deps --unrequired --unrequired --quiet | pacman --remove --nosave --recursive -; pacman --sync --clean
# And if switching to short form of all options, the one-liner can be made as short as this:
#   pacman -Sy --needed archlinux-keyring && pacman -Su && pacman -Qttdq | pacman -Rns -; pacman -Sc
# For the forced full upgrade (--force):
#   pacman --sync --refresh --refresh --needed archlinux-keyring && pacman --sync --sysupgrade --sysupgrade && pacman --query --deps --unrequired --unrequired --quiet | pacman --remove --nosave --recursive -; pacman --sync --clean
# And if switching to short form of all options:
#   pacman -Syy --needed archlinux-keyring && pacman -Suu && pacman -Qttdq | pacman -Rns -; pacman -Sc
# If necessary, sudo must be added to all pacman commands, except the
# "pacman -Qttdq" / "pacman --query --deps --unrequired --unrequired --quiet".
# Remember to either do both --refresh (-y) and --sysupgrade (-u), or none of them,
# at least never just --refresh (-y) which will easily lead to a bad state of partial
# upgrades!
#
# NOTE: Assumes basic tools are already installed, including sudo.
# Run script ./arch-setup first to ensure this!
#

# Parse arguments.
# The argument --force is consumed here. All other recognized options are
# collected into args_passthrough and then used to rebuild $@ to be passed
# through to all pacman commands.
force=0
args_passthrough=
while [ $# -gt 0 ]; do
    case "$1" in
        --force)                                force=1; shift ;;
        --noconfirm|--noprogressbar|--quiet|-q|--verbose|-v) args_passthrough="${args_passthrough} $1"; shift ;;
        --color=*)                              args_passthrough="${args_passthrough} $1"; shift ;;
        --color)
            [ $# -ge 2 ] || { printf 'Missing value for --color\n' >&2; exit 1; }
            args_passthrough="${args_passthrough} $1 $2"; shift 2 ;;
        *) printf 'Unknown argument: %s\n' "$1" >&2; exit 1 ;;
    esac
done
# Intentional unquoted expansion: word splitting rebuilds $@ correctly here
# because all passthrough argument values (e.g. "always" for --color) are
# single words containing no whitespace or glob characters.
# shellcheck disable=SC2086
set -- $args_passthrough
unset args_passthrough

#
# Update the package database.
# In regular mode: refreshes only if needed (single --refresh).
# In forced mode: forces refresh even if it appears up-to-date (double --refresh).
#
# Note that this is a bit dangerous to do without upgrading packages as
# well, since it may lead to a bad state of partial upgrades, but it is
# intentional because we want to install/upgrade the keyring package first,
# before we upgrade all packages.
#
echo
if [ "$force" -eq 1 ]; then
    echo "Forcing update of package database..."
    if ! sudo pacman --sync --refresh --refresh "$@"; then
        echo "Failed!" >&2
        exit 1
    fi
else
    echo "Ensuring package database is updated..."
    if ! sudo pacman --sync --refresh "$@"; then
        echo "Failed!" >&2
        exit 1
    fi
fi

#
# Ensure keyring contains the latest official set of packager keys.
#
# The package archlinux-keyring contains the official set of keys. Assuming
# it is preinstalled: Newer versions of Arch comes with the "base" meta package
# preinstalled, and newer versions of that includes the archlinux-keyring package.
# Previously the archlinux-keyring package would be implicitly included as pacman
# version 6.0.1-5 and older had a dependency to it, but pacman version 6.0.1-6
# removed the dependency to archlinux-keyring, and archlinux-keyring version
# 20220713-2 added dependency to pacman instead, and then base version 3-1 was
# extended to include archlinux-keyring in addition to pacman.
#
echo
echo "Ensuring latest keyring package is installed..."
if ! sudo pacman --sync --needed "$@" archlinux-keyring; then
    echo "Failed!" >&2
    echo "NOTE: The package database was previously successfully updated, but due to this" >&2
    echo "error when attempting to install/upgrade the keyring package, existing packages" >&2
    echo "have not been upgraded! Make sure to repeat this script until it succeeds, at" >&2
    echo "least do not install any new packages before existing packages has been" >&2
    echo "successfully upgraded, or else you may get into a bad state of partial upgrades!" >&2
    exit 1
fi

#
# Upgrade packages.
# In regular mode: upgrades outdated packages without allowing downgrades (single
# --sysupgrade). Not performing another database refresh at this point, could add
# --refresh to do that, and even twice if we wanted to force the refresh.
# In forced mode: also allows downgrading packages to match the version currently
# in cache (double --sysupgrade), which is usually only relevant when switching
# package repositories and performing a full upgrade. It will interactively prompt
# for confirmation before proceeding should any downgrades be found, which could
# be avoided by adding --noconfirm.
#
echo
if [ "$force" -eq 1 ]; then
    echo "Performing full upgrade/downgrade of packages..."
    if ! sudo pacman --sync --sysupgrade --sysupgrade "$@"; then
        echo "Failed!" >&2
        echo "NOTE: The package database was previously successfully updated, but since the" >&2
        echo "upgrading of existing packages failed, make sure to repeat this script until it" >&2
        echo "succeeds, at least do not install any new packages before existing packages has" >&2
        echo "been successfully upgraded, or else you may get into a bad state of partial" >&2
        echo "upgrades!" >&2
        exit 1
    fi
else
    echo "Upgrading any outdated packages..."
    if ! sudo pacman --sync --sysupgrade "$@"; then
        echo "Failed!" >&2
        echo "NOTE: The package database was previously successfully updated, but since the" >&2
        echo "upgrading of existing packages failed, make sure to repeat this script until it" >&2
        echo "succeeds, at least do not install any new packages before existing packages has" >&2
        echo "been successfully upgraded, or else you may get into a bad state of partial" >&2
        echo "upgrades!" >&2
        exit 1
    fi
fi
unset force

#
# Uninstall any unrequired packages left behind (orphans).
# Considering packages that were not explicitly installed, but originally installed as a
# dependency of other packages, even as an optional dependency due to the double --unrequired.
#
echo
echo "Searching for unrequired packages..."
#echo "* Note that when none are found it is expected to see \"error: argument '-' specified with empty stdin\""
#pacman --query --deps --unrequired --unrequired --quiet | sudo pacman --remove --nosave --recursive "$@" -
if orphans=$(pacman --query --deps --unrequired --unrequired --quiet) && [ -n "$orphans" ]; then
    echo "Removing unrequired packages..."
    # This works, assuming default IFS lead to correct splitting of argument, and because in Arch:
    # Package names can contain only alphanumeric characters and any of @, ., _, +, -. Names are not
    # allowed to start with hyphens or dots. All letters should be lowercase.
    if ! sudo pacman --remove --nosave --recursive "$@" $orphans; then
        echo "Failed!" >&2
        exit 1
    fi
fi
unset orphans

#
# Clean the package database (cache).
# Removing packages that are no longer installed to free up disk space.
# To completely delete the database, also packages that are currently
# installed, we could add another --clean.
# This will interactively prompt for confirmation before proceeding, unless
# --noconfirm is also added.
#
echo
echo "Cleanup package cache..."
if ! sudo pacman --sync --clean "$@"; then
    echo "Failed!" >&2
    exit 1
fi

