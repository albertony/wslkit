#!/bin/sh
#
# Uninstalls development environment for Claude Code for current user.
#
# This cleans up as much as possible from what the installation script does.
# It cleans up according to known paths for a regular install, which also
# covers a standalone install, although it does not use all of them. It can
# also be used for other setups, e.g. a strictly official standard
# installation. It may be too invasive for some scenarios, its primary use
# case is for testing Claude Code installations etc.
#
# This script considers default locations known to be used by Claude, and also
# environment variables that Claude is known to check for custom locations.
# The defaults are all within the current user's home directory. Claude
# considers environment variable CLAUDE_CONFIG_DIR, falling back to ~/.claude
# for main configuration. It does not consider XDG_CONFIG_HOME. For other
# files, Claude adheres to the XDG standard, considering base directories from
# environment variables XDG_DATA_HOME, XDG_STATE_HOME and XDG_CACHE_HOME,
# falling back to ~/.local/share, ~/.local/state and ~/.cache respectively.
#
# Removes the application executables and the global/user configuration. Also
# removes any remaining empty directories from the user home, assuming if they
# are now empty it was Claude Code that created them. The directories
# considered are commonly used Linux directories but do not exist by default
# in plain Arch Linux filesystem, and Claude Code creates them during the
# regular install procedure, or on first start, so should be safe and get us
# most cleanly back to original state if we delete them.
#
# Any project directories you have worked with from Claude Code may have gotten
# their own .claude subdirectory with project-specific configuration files.
# These are of course not cleaned up by this script. There is one exception:
# If the home directory has been opened in Claude Code, then we may have gotten
# an additional configuration file ${config_dir}/settings.local.json for local
# project settings of the home directory, in addition to the existing
# ${config_dir}/settings.json for user settings which overlaps with the shared
# project settings for the home directory. We will delete both of these.
#
# Passes any script arguments to the pacman commands, so can execute script with
# --noconfirm for instance to run non-interactively proceeding without prompting
# user.
#

# If we could always assume that the distro is always set up with a non-root
# default user, then we could verify we are not running as root, since this
# considers a local Claude Code installation for the current user only!
#if [ ${EUID:-$(id -u)} -eq 0 ]; then
#    echo 'Please do not run this script as root' >&2
#    exit 1
#fi

# Resolve XDG conventional user binary directory.
# This is where the Claude executable is installed by default, and here we
# assume it was not manually installed elsewhere.
bin_dir="${HOME}/.local/bin"

# Resolve Claude-specific configuration directory and global configuration
# file. The config directory is ~/.claude by default, overridden by
# CLAUDE_CONFIG_DIR. The global configuration file is ~/.claude.json by
# default, but stored as .claude.json inside the config directory when
# CLAUDE_CONFIG_DIR is set. Claude does not consider XDG_CONFIG_HOME for
# either of these.
config_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
if [ -n "${CLAUDE_CONFIG_DIR}" ]; then
    claude_json="${CLAUDE_CONFIG_DIR}/.claude.json"
else
    claude_json="${HOME}/.claude.json"
fi

# Resolve XDG standard base directories, falling back to XDG defaults.
# Ignoring XDG_CONFIG_HOME as per comment above.
data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
cache_home="${XDG_CACHE_HOME:-$HOME/.cache}"

# Remove application files.
echo "Removing application files..."
echo "Considering binary directory '${bin_dir}'"
echo "Considering data directory '${data_home}'"
rm --force "${bin_dir}/claude" # In regular setup this is a symlink to the current version of the application executable, in standalone this is the actual executable
rm --recursive --force "${data_home}/claude" # In regular setup this contains multiple versions of the actual application executable
rm --force "${data_home}/applications/claude-code-url-handler.desktop"

# Remove data files.
echo "Removing data files..."
echo "Considering global configuration file '${claude_json}'"
echo "Considering configuration directory '${config_dir}'"
echo "Considering cache directory '${cache_home}'"
echo "Considering state directory '${state_home}'"
rm --force "${claude_json}" # Remove global settings, with user preferences, OAuth session, state etc.
rm --recursive --force "${config_dir}" # Remove configuration directory, with user settings, backups, downloads, cache
rm --recursive --force "${cache_home}/claude" # Cache
rm --recursive --force "${cache_home}/claude-cli-nodejs" # Cache
rm --recursive --force "${state_home}/claude" # Locks

# Cleanup remaining empty directories.
echo "Cleaning up remaining empty directories..."
find "${bin_dir}" -type d -empty -delete 2> /dev/null
find "${data_home}" -type d -empty -delete 2> /dev/null
find "${state_home}" -type d -empty -delete 2> /dev/null
find "${cache_home}" -type d -empty -delete 2> /dev/null
rmdir "${HOME}/.config" 2> /dev/null # Remove parent of default config dir if now empty (not XDG-governed)
rmdir "${HOME}/.local" 2> /dev/null # Remove parent of default bin, data and state dir if now empty (not XDG-governed)

# Just leave the PATH variable! There are so many ways this can be set, and the
# install script sets a bit complex conditional expression, so a simple regex
# is not enough. It is not really Claude-specific anyway, it is the XDG
# conventional location for locally installed executable files so should be
# fine to just leave it.
# OLD:
#echo "Cleaning up PATH variable..."
#if [ ! -d "${bin_dir}" ] && [ -f "${HOME}/.bashrc" ]; then
#    if grep --quiet --extended-regexp '^export PATH="\$\{?HOME\}?/\.local/bin:\$\{?PATH\}?"$' "${HOME}/.bashrc"; then
#        sed --in-place '/^export PATH="\${HOME}\/\.local\/bin:\${PATH}"$/d' "${HOME}/.bashrc"
#        echo "Removed from user profile '.bashrc' the entry that added the now-removed '${bin_dir}' to PATH"
#        echo "NOTICE: You should restart the shell session to refresh the environment variables"
#    fi
#fi

echo "Cleaning up CLAUDE_CONFIG_DIR variable..."
if [ -f "${HOME}/.bashrc" ]; then
    if grep --quiet --extended-regexp '^export CLAUDE_CONFIG_DIR=' "${HOME}/.bashrc"; then
        sed --in-place '/^export CLAUDE_CONFIG_DIR=.*$/d' "${HOME}/.bashrc"
        echo "Removed from user profile '.bashrc' the entry that set CLAUDE_CONFIG_DIR"
        echo "NOTICE: You should restart the shell session to refresh the environment variables"
    fi
fi

# Claude may also create or update the global gitignore for the user, to ignore
# local (personal) project settings files, matching '**/.claude/settings.local.json'.
# Note that it does not consider XDG_CONFIG_HOME for this either, so it is always
# referring to file ~/.config/git/ignore.
echo "Cleaning up global git ignore..."
if [ -f "${HOME}/.config/git/ignore" ]; then
    if grep --quiet '^\*\*/\.claude/settings\.local\.json$' "${HOME}/.config/git/ignore"; then
        sed --in-place '/^\*\*\/\.claude\/settings\.local\.json$/d' "${HOME}/.config/git/ignore"
        echo "Removed line '**/.claude/settings.local.json' from file '${HOME}/.config/git/ignore'"
        if [ ! -s "${HOME}/.config/git/ignore" ]; then
            echo "The file is now empty so deleting it"
            rm "${HOME}/.config/git/ignore"
            rmdir "${HOME}/.config/git" 2> /dev/null
            rmdir "${HOME}/.config" 2> /dev/null
        fi
    fi
    if [ -f "${HOME}/.config/git/ignore" ] && grep --quiet '/\.claude/' "${HOME}/.config/git/ignore"; then
        echo "WARNING: The file '${HOME}/.config/git/ignore' still contains a path containing '/.claude/' which must be cleaned up manually"
    fi
fi

echo "Checking dependencies..."
# Sandboxed mode requires additional dependencies.
# Currently we just check for them, to keep the install script user-specific,
# and avoid requiring sudo.
if pacman -Qi socat > /dev/null 2>&1; then
    echo "WARNING: The package socat can now be removed if it was installed just to support Claude sandboxed mode"
fi
if pacman -Qi bubblewrap > /dev/null 2>&1; then
    echo "WARNING: The package bubblewrap can now be removed if it was installed just to support Claude sandboxed mode"
fi
