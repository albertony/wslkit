#!/bin/sh
#
# Uninstalls development environment for Claude Code for current user.
#
# This cleans up as much as possible from what the installation script does.
# It cleans according known paths for a regular install, which also covers a
# standalone install, although it does not use of all them. Assuming default
# locations are used, i.e. well-known locations within the current user's home
# directory, and that there is not set a custom location environment variable
# CLAUDE_CONFIG_DIR. It can also be used for other setups, e.g. a strictly
# official standard installation. It may be too invasive for some scenarios,
# it's primary use case is for testing Claude Code installations etc.
#
# Removes the application executables and the global/user configuration. Also
# removes any remaining empty directories from the user home, assuming if they
# are now empty it was Claude Code that created them. The directories
# considered are commonly used Linux directories but does not exist by default
# in plain Arch Linux filesystem, and Claude Code creates them during the
# regular install procedure, or on first start, so should be safe and get us
# most cleanly back to original state if we delete them.
#
# Any project directories you have worked with from Claude Code may have gotten
# their own .claude subdirectory with project-specific configuration files.
# These are of course not cleaned up by this script. There is one exception:
# If the home directory has been opened in Claude Code, then we may have gotten
# an additional configuration file ~/.claude/settings.local.json for local
# project settings of the home directory, in addition to the existing
# ~/.claude/settings.json for user settings which overlaps with the shared
# project settings for the home directory. We will delete both of these.
#
# Passes any script arguments to the pacman commands, so can execute script with
# --noconfirm for instance to run non-interactively proceeding without prompting
# user.
#

# If we could always assume that the distro is always set up with a non-root
# default user, then we couuld verify we are not not running as root, since
# this considers a local Claude Code installation for the current user only!
#if [ ${EUID:-$(id -u)} -eq 0 ]; then
#    echo 'Please do not run this script as root' >&2
#    exit 1
#fi

# Remove application files.
echo "Removing application files..."
rm --force "${HOME}/.local/bin/claude" # In regular setup this is a symlink to the current version of the application executable, in standalone this is the actual executable
rm --recursive --force "${HOME}/.local/share/claude" # In regular setup this contains multiples versions of the actual application executable
rm --force "${HOME}/.local/share/applications/claude-code-url-handler.desktop"

# Remove data files.
echo "Removing data files..."
rm --force "${HOME}/.claude.json" # Remove user preferences, OAuth session, state etc.
rm --recursive --force "${HOME}/.claude" # Remove default CLAUDE_CONFIG_DIR, with user settings, backups, downloads, cache
rm --recursive --force "${HOME}/.local/state/claude" # Locks
rm --recursive --force "${HOME}/.cache/claude" # Cache
rm --recursive --force "${HOME}/.cache/claude-cli-nodejs" # Cache

# Cleanup remaining empty directories.
echo "Cleaning up remaining empty directories..."
find "${HOME}/.local" -type d -empty -delete 2> /dev/null
find "${HOME}/.cache" -type d -empty -delete 2> /dev/null
# Alternative, pinpointing known subdirectories:
#rmdir "${HOME}/.local/bin" 2> /dev/null
#rmdir "${HOME}/.local/share" 2> /dev/null
#rmdir "${HOME}/.local/state" 2> /dev/null
#rmdir "${HOME}/.local" 2> /dev/null
#rmdir "${HOME}/.cache/claude-cli-nodejs" 2> /dev/null
#rmdir "${HOME}/.cache" 2> /dev/null

echo "Cleaning up PATH variable..."
if [ ! -d "${HOME}/.local/bin" ] && [ -f "${HOME}/.bashrc" ]; then
    if grep --quiet --extended-regexp '^export PATH="\$\{?HOME\}?/\.local/bin:\$\{?PATH\}?"$' "${HOME}/.bashrc"; then
        sed --in-place '/^export PATH="\${HOME}\/\.local\/bin:\${PATH}"$/d' "${HOME}/.bashrc"
        echo "Removed from '~/.bashrc' the entry that added the now-removed '~/.local/bin' to PATH"
    fi
fi

# Claude may also create or update the global gitignore for the user, to ignore
# local (personal) project settings files, matching '**/.claude/settings.local.json'.
echo "Cleaning up global git ignore..."
if [ -f "${HOME}/.config/git/ignore" ]; then
    if grep --quiet '^\*\*/\.claude/settings\.local\.json$' "${HOME}/.config/git/ignore"; then
        sed --in-place '/^\*\*\/\.claude\/settings\.local\.json$/d' "${HOME}/.config/git/ignore"
        echo "Removed line '**/.claude/settings.local.json' from file '~/.config/git/ignore'"
        if [ ! -s "${HOME}/.config/git/ignore" ]; then
            echo "The file '~/.config/git/ignore' is now empty so deleting it"
            rm "${HOME}/.config/git/ignore"
            rmdir "${HOME}/.config/git" 2> /dev/null
            rmdir "${HOME}/.config" 2> /dev/null
        fi
    fi
    if [ -f "${HOME}/.config/git/ignore" ] && grep --quiet '/\.claude/' "${HOME}/.config/git/ignore"; then
        echo "WARNING: The global git ignore file '~/.config/git/ignore' still contains a path containing '/.claude/' which must be cleaned up manually"
    fi
fi

# This install script installs packages for the optional dependencies socat
# and bubblewrap, so for a clean uninstall we should remove them. But it may
# be a bit risky, as they could have been already installed when we installed
# Claude, and also others may now depend on them! However, unless this script
# is executed with argument --noconfirm, the user will be prompted for
# confirmation.
echo "Removing packages..."
if ! sudo pacman --remove --nosave --recursive "$@" socat bubblewrap; then
    echo "WARNING: Could not remove socat/bubblewrap — they may already be uninstalled or required by another package"
fi

#
# Clean the package database (cache).
# Removing packages that are no longer installed to free up disk space,
# assuming we removed either socat or bubblewrap or both above, these can be
# removed from cache at least.
# This will interactively prompt for confirmation before proceeding, unless
# --noconfirm is also added.
#
echo
echo "Cleanup package cache..."
if ! sudo pacman --sync --clean "$@"; then
    echo "Failed!" >&2
    exit 1
fi
